---
import MainLayout from '../layouts/MainLayout.astro';
import { env } from 'cloudflare:workers';

// Leer los equipos desde la base de datos D1
const db = env.DB;
const { results: equipos } = await db.prepare(
    'SELECT * FROM productos WHERE categoria = ? AND activo = 1 ORDER BY nombre'
).bind('equipos').all();
---

<MainLayout title="Catálogo de Equipos" description="Explora nuestra colección de equipos para el agua de tu acuario en GuppyLandia, Tulcán.">

    <!-- Header de Página -->
    <section class="section" style="padding-bottom: 0;">
        <div class="container">
            <div class="section-title">
                <h2>Catálogo de <span>Equipos para tu Acuario</span></h2>
            </div>
        </div>
    </section>

    <!-- Grid de Productos -->
    <section class="section">
        <div class="container">
            <div class="products">
                {equipos.map((equipo: any) => (
                    <div class="product-card">
                        {equipo.stock <= 3 ? (
                            <div class="stock-badge stock-low">¡Quedan {equipo.stock}!</div>
                        ) : (
                            <div class="stock-badge stock-ok">En stock</div>
                        )}
                        <img src={equipo.imagen} alt={equipo.nombre} style="object-fit: contain; border-radius: 20px;">
                        <h4>{equipo.nombre}</h4>
                        <p style="color: #728697; margin-bottom: 12px; line-height: 1.6; flex-grow: 1;">{equipo.descripcion}</p>
                        <div class="price">${Number(equipo.precio).toFixed(2)}</div>
                        <div class="qty-selector">
                            <button type="button" onclick="changeQty(this, -1)">−</button>
                            <span class="qty-value">1</span>
                            <button type="button" onclick="changeQty(this, 1)">+</button>
                        </div>
                        <button class="product-btn" onclick={`addToCart('${equipo.nombre}', ${equipo.precio}, getQtyFromCard(this), event)`}>Agregar al carrito</button>
                    </div>
                ))}
            </div>
        </div>
    </section>

</MainLayout>