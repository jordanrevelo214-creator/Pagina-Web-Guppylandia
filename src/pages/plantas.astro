---
import MainLayout from '../layouts/MainLayout.astro';

const plantas = [
    { nombre: "Cryptocoryne wendtii 'Green'", precio: 3.50, stock: 15, descripcion: "Plantas de acuario de fácil cuidado y crecimiento lento.", imagen: "https://i.etsystatic.com/22016538/r/il/0f365a/2552530212/il_794xN.2552530212_1voc.jpg" },
    { nombre: "Lysmachia nummularia 'Aurea'", precio: 12.00, stock: 2, descripcion: "Una planta terrestre que se adapta muy bien a la acuariofilia.", imagen: "https://www.lumalightstudio.com.mx/cdn/shop/products/Lysimachia_nummularia_aurea_3_1200x_78469105-c148-40a4-abd5-004d39afe887_720x.jpg?v=1638819012" },
    { nombre: "Cryptocoryne pontederiifolia", precio: 1.50, stock: 50, descripcion: "Una planta con hojas grandes y un tallo robusto, ideal para acuarios medianos y grandes.", imagen: "https://d2seqvvyy3b8p2.cloudfront.net/66e4a6c35ca20c625d8b3ea78188f19b.jpg" },
    { nombre: "Hygrophila polysperma", precio: 2.50, stock: 3, descripcion: "Su belleza y color cambia dependiendo de la luz. Crecimiento rápido.", imagen: "https://aquariumbreeder.com/wp-content/uploads/2024/01/Hygrophila-Polysperma-Care-Guide-%E2%80%93-Planting-Growing-and-Propagation.jpg" },
];
---

<MainLayout title="Catálogo de Plantas" description="Explora nuestra colección de plantas acuáticas en GuppyLandia, Tulcán.">

    <!-- Header de Página -->
    <section class="section" style="padding-bottom: 0;">
        <div class="container">
            <div class="section-title">
                <h2>Catálogo de <span>Plantas</span></h2>
            </div>
        </div>
    </section>

    <!-- Grid de Productos -->
    <section class="section">
        <div class="container">
            <div class="products">
                {plantas.map((planta) => (
                    <div class="product-card">
                        {planta.stock <= 3 ? (
                            <div class="stock-badge stock-low">¡Quedan {planta.stock}!</div>
                        ) : (
                            <div class="stock-badge stock-ok">En stock</div>
                        )}
                        <img src={planta.imagen} alt={planta.nombre} style="object-fit: cover; border-radius: 20px;">
                        <h4>{planta.nombre}</h4>
                        <p style="color: #728697; margin-bottom: 12px; line-height: 1.6; flex-grow: 1;">{planta.descripcion}</p>
                        <div class="price">${planta.precio.toFixed(2)}</div>
                        <div class="qty-selector">
                            <button type="button" onclick="changeQty(this, -1)">−</button>
                            <span class="qty-value">1</span>
                            <button type="button" onclick="changeQty(this, 1)">+</button>
                        </div>
                        <button class="product-btn" onclick={`addToCart('${planta.nombre}', ${planta.precio}, getQtyFromCard(this), event)`}>Agregar al carrito</button>
                    </div>
                ))}
            </div>
        </div>
    </section>

</MainLayout>
