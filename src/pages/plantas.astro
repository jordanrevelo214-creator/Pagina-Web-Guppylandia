---
import MainLayout from '../layouts/MainLayout.astro';
import { env } from 'cloudflare:workers';

// Leer las plantas desde la base de datos D1
const db = env.DB;
const { results: plantas } = await db.prepare(
    'SELECT * FROM productos WHERE categoria = ? AND activo = 1 ORDER BY nombre'
).bind('plantas').all();
---

<MainLayout title="Catálogo de Plantas" description="Explora nuestra colección de plantas acuáticas en GuppyLandia, Tulcán.">

    <!-- Header de Página -->
    <section class="section" style="padding-bottom: 0;">
        <div class="container">
            <div class="section-title">
                <h2>Catálogo de <span>Plantas</span></h2>
            </div>
        </div>
    </section>

    <!-- Grid de Productos -->
    <section class="section">
        <div class="container">
            <div class="products">
                {plantas.map((planta: any) => (
                    <div class="product-card">
                        {planta.stock <= 3 ? (
                            <div class="stock-badge stock-low">¡Quedan {planta.stock}!</div>
                        ) : (
                            <div class="stock-badge stock-ok">En stock</div>
                        )}
                        <img src={planta.imagen} alt={planta.nombre} style="object-fit: cover; border-radius: 20px;">
                        <h4>{planta.nombre}</h4>
                        <p style="color: #728697; margin-bottom: 12px; line-height: 1.6; flex-grow: 1;">{planta.descripcion}</p>
                        <div class="price">${Number(planta.precio).toFixed(2)}</div>
                        <div class="qty-selector">
                            <button type="button" onclick="changeQty(this, -1)">−</button>
                            <span class="qty-value">1</span>
                            <button type="button" onclick="changeQty(this, 1)">+</button>
                        </div>
                        <button class="product-btn" onclick={`addToCart('${planta.nombre}', ${planta.precio}, getQtyFromCard(this), event)`}>Agregar al carrito</button>
                    </div>
                ))}
            </div>
        </div>
    </section>

</MainLayout>
