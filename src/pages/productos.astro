---
import MainLayout from '../layouts/MainLayout.astro';
import { env } from 'cloudflare:workers';

// Leer los productos desde la base de datos D1
const db = env.DB;
const { results: productos } = await db.prepare(
    'SELECT * FROM productos WHERE categoria = ? AND activo = 1 ORDER BY nombre'
).bind('productos').all();
---

<MainLayout title="Catálogo de Productos" description="Explora nuestra colección de productos para el agua de tu acuario en GuppyLandia, Tulcán.">

    <!-- Header de Página -->
    <section class="section" style="padding-bottom: 0;">
        <div class="container">
            <div class="section-title">
                <h2>Catálogo de <span>Productos para el agua de tu Acuario</span></h2>
            </div>
        </div>
    </section>

    <!-- Grid de Productos -->
    <section class="section">
        <div class="container">
            <div class="products">
                {productos.map((producto: any) => (
                    <div class="product-card">
                        {producto.stock <= 3 ? (
                            <div class="stock-badge stock-low">¡Quedan {producto.stock}!</div>
                        ) : (
                            <div class="stock-badge stock-ok">En stock</div>
                        )}
                        <img src={producto.imagen} alt={producto.nombre} style="object-fit: cover; border-radius: 20px;">
                        <h4>{producto.nombre}</h4>
                        <p style="color: #728697; margin-bottom: 12px; line-height: 1.6; flex-grow: 1;">{producto.descripcion}</p>
                        <div class="price">${Number(producto.precio).toFixed(2)}</div>
                        <div class="qty-selector">
                            <button type="button" onclick="changeQty(this, -1)">−</button>
                            <span class="qty-value">1</span>
                            <button type="button" onclick="changeQty(this, 1)">+</button>
                        </div>
                        <button class="product-btn" onclick={`addToCart('${producto.nombre}', ${producto.precio}, getQtyFromCard(this), event)`}>Agregar al carrito</button>
                    </div>
                ))}
            </div>
        </div>
    </section>

</MainLayout>
