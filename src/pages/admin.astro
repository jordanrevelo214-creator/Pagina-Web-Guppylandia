---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Panel de Administración" description="Panel de administración de GuppyLandia">

<section class="section" style="padding-top: 40px;">
    <div class="container">

        <!-- LOGIN -->
        <div id="login-screen" class="admin-login">
            <div class="admin-login-card">
                <i class="fa-solid fa-lock" style="font-size: 48px; color: #4cb7c9; margin-bottom: 20px;"></i>
                <h2>Panel de Administración</h2>
                <p style="color: #728697; margin-bottom: 24px;">Ingresa la contraseña para gestionar productos</p>
                <input type="password" id="admin-password" placeholder="Contraseña" class="admin-input">
                <button id="login-btn" class="btn btn-primary" style="width: 100%; text-align: center;">Ingresar</button>
                <p id="login-error" style="color: #dc2626; margin-top: 12px; display: none;">Contraseña incorrecta</p>
            </div>
        </div>

        <!-- PANEL ADMIN (oculto hasta login) -->
        <div id="admin-panel" style="display: none;">
            <div class="section-title" style="margin-bottom: 30px;">
                <h2>Gestión de <span>Productos</span></h2>
            </div>

            <!-- Botón agregar + filtros -->
            <div class="admin-toolbar">
                <div class="admin-filters">
                    <button class="admin-filter-btn active" onclick="filterCategory('todos')">Todos</button>
                    <button class="admin-filter-btn" onclick="filterCategory('peces')">🐠 Peces</button>
                    <button class="admin-filter-btn" onclick="filterCategory('plantas')">🌿 Plantas</button>
                    <button class="admin-filter-btn" onclick="filterCategory('productos')">🧪 Productos</button>
                    <button class="admin-filter-btn" onclick="filterCategory('equipos')">⚙️ Equipos</button>
                </div>
                <button class="btn btn-primary" onclick="openModal()">
                    <i class="fa-solid fa-plus"></i> Agregar Producto
                </button>
                <button class="btn btn-secondary" onclick="openPasswordModal()" style="padding: 10px 20px; margin-left: 10px; border-radius: 16px; font-size: 14px; height: 46px; display: inline-flex; align-items: center; gap: 8px;">
                    <i class="fa-solid fa-key"></i> Contraseña
                </button>
                <button class="cart-btn-clear" onclick="logout()" style="padding: 10px 20px; margin-left: 10px;">
                    <i class="fa-solid fa-right-from-bracket"></i> Salir
                </button>
            </div>

            <!-- Tabla de productos -->
            <div class="admin-table-container">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Imagen</th>
                            <th>Nombre</th>
                            <th>Categoría</th>
                            <th>Precio</th>
                            <th>Stock</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="products-table-body">
                    </tbody>
                </table>
            </div>

            <p id="admin-empty" style="text-align: center; color: #728697; padding: 40px; display: none;">
                No hay productos en esta categoría
            </p>
        </div>
    </div>
</section>

<!-- MODAL para agregar/editar producto -->
<div id="product-modal" class="modal-overlay" style="display: none;">
    <div class="modal-content">
        <div class="modal-header">
            <h3 id="modal-title">Agregar Producto</h3>
            <button class="cart-close" onclick="closeModal()">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        <form id="product-form" class="modal-form">
            <input type="hidden" id="product-id">
            
            <label>Nombre *</label>
            <input type="text" id="product-nombre" class="admin-input" required placeholder="Ej: Betta Halfmoon">
            
            <label>Categoría *</label>
            <select id="product-categoria" class="admin-input" required>
                <option value="">Seleccionar...</option>
                <option value="peces">🐠 Peces</option>
                <option value="plantas">🌿 Plantas</option>
                <option value="productos">🧪 Productos</option>
                <option value="equipos">⚙️ Equipos</option>
            </select>
            
            <div class="modal-row">
                <div>
                    <label>Precio ($) *</label>
                    <input type="number" id="product-precio" class="admin-input" required step="0.01" min="0" placeholder="0.00">
                </div>
                <div>
                    <label>Stock</label>
                    <input type="number" id="product-stock" class="admin-input" min="0" placeholder="0">
                </div>
            </div>
            
            <label>Descripción</label>
            <textarea id="product-descripcion" class="admin-input" rows="3" placeholder="Descripción del producto..."></textarea>
            
            <label>Imagen del Producto</label>
            <div class="modal-row" style="gap: 10px; align-items: flex-end; margin-bottom: 12px;">
                <div style="flex-grow: 1;">
                    <input type="text" id="product-imagen" class="admin-input" placeholder="Pegar URL (https://...) o subir archivo..." style="margin-bottom: 0;">
                </div>
                <div>
                    <label class="btn btn-secondary" style="padding: 14px 20px; cursor: pointer; border-radius: 16px; font-size: 14px; display: inline-flex; align-items: center; gap: 8px; margin-bottom: 0; white-space: nowrap; height: 50px;">
                        <i class="fa-solid fa-upload"></i> Subir
                        <input type="file" id="product-file" accept="image/*" style="display: none;">
                    </label>
                </div>
            </div>
            
            <div id="image-preview-container" style="margin-top: 10px; margin-bottom: 15px; display: none; align-items: center; gap: 15px; background: #f0f7f8; padding: 10px; border-radius: 16px; border: 1px solid #e0f2f4;">
                <img id="image-preview" src="" style="width: 70px; height: 70px; object-fit: contain; border-radius: 12px; background: white; border: 1px solid #d5eef0;">
                <div style="flex-grow: 1;">
                    <span style="font-size: 12px; color: #4caab7; font-weight: 600; display: block;">Vista previa de imagen</span>
                    <span id="image-size-info" style="font-size: 11px; color: #728697;">Imagen lista</span>
                </div>
                <button type="button" class="cart-btn-clear" id="remove-image-btn" style="padding: 6px 12px; color: #dc2626; border-radius: 10px; font-size: 12px;">
                    <i class="fa-solid fa-trash"></i> Quitar
                </button>
            </div>
            
            <div style="margin-bottom: 20px; display: flex; align-items: center; gap: 10px; background: #fffdf5; padding: 12px; border-radius: 16px; border: 1px solid #ffeeba;">
                <input type="checkbox" id="product-destacado" style="width: 20px; height: 20px; cursor: pointer; accent-color: #f59e0b;">
                <label for="product-destacado" style="margin-bottom: 0; font-weight: 600; color: #b45309; cursor: pointer; display: flex; align-items: center; gap: 6px;">
                    <i class="fa-solid fa-star" style="color: #f59e0b;"></i> Destacar este producto en la página de inicio
                </label>
            </div>
            
            <div class="modal-actions">
                <button type="button" class="cart-btn-clear" onclick="closeModal()">Cancelar</button>
                <button type="submit" class="btn btn-primary">Guardar</button>
            </div>
        </form>
    </div>
</div>

<!-- MODAL para cambiar contraseña -->
<div id="password-modal" class="modal-overlay" style="display: none;">
    <div class="modal-content" style="max-width: 400px;">
        <div class="modal-header">
            <h3><i class="fa-solid fa-key" style="color: #4cb7c9;"></i> Cambiar Contraseña</h3>
            <button class="cart-close" onclick="closePasswordModal()">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        <form id="password-form" class="modal-form">
            <label>Contraseña Actual *</label>
            <input type="password" id="current-password" class="admin-input" required placeholder="Ingresa contraseña actual">
            
            <label>Nueva Contraseña *</label>
            <input type="password" id="new-password" class="admin-input" required placeholder="Mínimo 6 caracteres">
            
            <p id="password-error" style="color: #dc2626; font-size: 13px; display: none; margin-bottom: 12px; font-weight: 500;"></p>
            <p id="password-success" style="color: #16a34a; font-size: 13px; display: none; margin-bottom: 12px; font-weight: 500;">¡Contraseña actualizada con éxito!</p>
            
            <div class="modal-actions">
                <button type="button" class="cart-btn-clear" onclick="closePasswordModal()">Cancelar</button>
                <button type="submit" class="btn btn-primary">Actualizar</button>
            </div>
        </form>
    </div>
</div>

<script is:inline src="/js/admin.js"></script>

</MainLayout>
